+bool ggml_cuda_flash_attn_ext_openturbo_supported(const ggml_tensor * dst) {
+    return openturbo_is_decode_contract_supported(dst);
+}
+
+bool ggml_cuda_flash_attn_ext_openturbo(ggml_backend_cuda_context & ctx, ggml_tensor * dst) {
+    if (!openturbo_is_decode_contract_supported(dst)) {
+        return false;
+    }
+
+    const ggml_tensor * Q    = dst->src[0];
+    const ggml_tensor * K    = dst->src[1];
+    const ggml_tensor * V    = dst->src[2];
+    const ggml_tensor * mask = dst->src[3];
+
+    float scale = 1.0f;
+    memcpy(&scale, (const float *) dst->op_params + 0, sizeof(float));
+
+    ggml_cuda_openturbo_sidecar_view sidecar_view;
+    if ((!ggml_cuda_openturbo_sidecar_lookup(K, &sidecar_view) || !sidecar_view.contiguous_prefix) &&
+        !ggml_cuda_openturbo_sidecar_rebuild_from_cache_tensor(ctx, K)) {
+        return false;
+    }
+
+    if (!ggml_cuda_openturbo_sidecar_lookup(K, &sidecar_view) || !sidecar_view.contiguous_prefix) {
+        return false;
+    }
+
+    const int    num_query_heads    = static_cast<int>(Q->ne[2]);
+    const int    num_kv_heads       = static_cast<int>(K->ne[2]);
+    const int    query_head_group   = num_query_heads / num_kv_heads;
+    const int    num_cache_tokens   = static_cast<int>(K->ne[1]);
+    const int    dv                 = static_cast<int>(V->ne[0]);
+    const int    query_header_count = num_query_heads;
+    const size_t score_count        = static_cast<size_t>(num_query_heads) * static_cast<size_t>(num_cache_tokens);
+    cudaStream_t stream             = ctx.stream();
+
+    openturbo_packed_tile_header_t * query_headers = nullptr;
+    float *                          scores        = nullptr;
+    int                              cuda_status   = cudaSuccess;
+
+    cuda_status =
+        cudaMalloc(&query_headers, sizeof(openturbo_packed_tile_header_t) * static_cast<size_t>(query_header_count));
+    if (cuda_status == cudaSuccess) {
+        cuda_status = cudaMalloc(&scores, sizeof(float) * score_count);
+    }
+    if (cuda_status != cudaSuccess) {
+        goto cleanup;
+    }
+
+    if (!openturbo_encode_tensor_tiles(Q, query_headers, query_header_count, stream, &cuda_status)) {
+        goto cleanup;
+    }
+
+    for (int query_head_index = 0; query_head_index < num_query_heads; ++query_head_index) {
+        const int                kv_head_index = query_head_index / query_head_group;
+        const openturbo_status_t scan_status   = openturbo_scan_query_many_cache_multi_tile(
+            query_headers + query_head_index,
+            sidecar_view.headers +
+                static_cast<size_t>(kv_head_index) * static_cast<size_t>(sidecar_view.rows_capacity) +
+                static_cast<size_t>(sidecar_view.row_offset),
+            scores + static_cast<size_t>(query_head_index) * static_cast<size_t>(num_cache_tokens), 1, num_cache_tokens,
+            stream, &cuda_status);
+        if (scan_status != OPENTURBO_STATUS_SUCCESS) {
+            goto cleanup;
+        }
+    }
+
+    if (mask == nullptr) {
+        openturbo_scores_to_probs_kernel<float, false>
+            <<<num_query_heads, kOpenturboSoftmaxThreads, 0, stream>>>(scores, nullptr, num_cache_tokens, scale);
+    } else if (mask->type == GGML_TYPE_F16) {
+        const half * mask_base =
+            reinterpret_cast<const half *>(static_cast<const char *>(mask->data) +
+                                           static_cast<size_t>(Q->ne[1] - 1) * static_cast<size_t>(mask->nb[1]));
+        openturbo_scores_to_probs_kernel<half, true>
+            <<<num_query_heads, kOpenturboSoftmaxThreads, 0, stream>>>(scores, mask_base, num_cache_tokens, scale);
+    } else {
+        const float * mask_base =
+            reinterpret_cast<const float *>(static_cast<const char *>(mask->data) +
+                                            static_cast<size_t>(Q->ne[1] - 1) * static_cast<size_t>(mask->nb[1]));
+        openturbo_scores_to_probs_kernel<float, true>
+            <<<num_query_heads, kOpenturboSoftmaxThreads, 0, stream>>>(scores, mask_base, num_cache_tokens, scale);
+    }
+    cuda_status = cudaGetLastError();
+    if (cuda_status != cudaSuccess) {
+        goto cleanup;
+    }
+
+    if (V->type == GGML_TYPE_F16) {
+        openturbo_weighted_value_sum_kernel<half><<<num_query_heads, kOpenturboValueThreads, 0, stream>>>(
+            scores, reinterpret_cast<const half *>(V->data), static_cast<float *>(dst->data), dv, num_cache_tokens,
+            num_query_heads, query_head_group, V->nb[0], V->nb[1], V->nb[2], dst->nb[0], dst->nb[1]);
+    } else {
+        openturbo_weighted_value_sum_kernel<float><<<num_query_heads, kOpenturboValueThreads, 0, stream>>>(
+            scores, static_cast<const float *>(V->data), static_cast<float *>(dst->data), dv, num_cache_tokens,
+            num_query_heads, query_head_group, V->nb[0], V->nb[1], V->nb[2], dst->nb[0], dst->nb[1]);
+    }
+    cuda_status = cudaGetLastError();
+    if (cuda_status != cudaSuccess) {
+        goto cleanup;
+    }
+
+    if (query_headers != nullptr) {
+        cudaFree(query_headers);
+    }
+    if (scores != nullptr) {
+        cudaFree(scores);
+    }
+    return true;
+
+cleanup:
+    if (query_headers != nullptr) {
+        cudaFree(query_headers);
+    }
+    if (scores != nullptr) {
+        cudaFree(scores);
+    }
+    return false;
+}
