+#    include <mutex>
+#    include <unordered_map>
+#    include <vector>
+
+namespace {
+struct ggml_cuda_openturbo_sidecar_entry {
+    openturbo_packed_tile_header_t * device_headers    = nullptr;
+    int64_t                          rows_capacity     = 0;
+    int64_t                          rows_per_stream   = 0;
+    int64_t                          n_stream          = 0;
+    int64_t                          n_past_hint       = 0;
+    int                              num_kv_heads      = 0;
+    bool                             contiguous_prefix = false;
+};
+
+std::mutex                                                                 g_openturbo_sidecar_mutex;
+std::unordered_map<const ggml_tensor *, ggml_cuda_openturbo_sidecar_entry> g_openturbo_sidecars;
+
+const ggml_tensor * openturbo_resolve_base_cache_tensor(const ggml_tensor * tensor) {
+    const ggml_tensor * current = tensor;
+    while (current != nullptr && current->view_src != nullptr) {
+        current = current->view_src;
+    }
+    return current;
+}
+
+bool openturbo_is_named_k_cache(const ggml_tensor * tensor) {
+    if (tensor == nullptr) {
+        return false;
+    }
+
+    const char * name = ggml_get_name(tensor);
+    return name != nullptr && std::strncmp(name, "cache_k_l", 8) == 0;
+}
+
+template <typename idx_t>
+__global__ void openturbo_scatter_encoded_rows_kernel(const openturbo_packed_tile_header_t * encoded_headers,
+                                                      const idx_t *                          row_indices,
+                                                      openturbo_packed_tile_header_t *       sidecar_headers,
+                                                      int                                    row_count,
+                                                      int                                    num_kv_heads,
+                                                      int64_t                                rows_capacity) {
+    const int linear_index = blockIdx.x * blockDim.x + threadIdx.x;
+    const int total        = row_count * num_kv_heads;
+    if (linear_index >= total) {
+        return;
+    }
+
+    const int     row_write_index = linear_index / num_kv_heads;
+    const int     kv_head_index   = linear_index - row_write_index * num_kv_heads;
+    const int64_t dst_row         = static_cast<int64_t>(row_indices[row_write_index]);
+    if (dst_row < 0 || dst_row >= rows_capacity) {
+        return;
+    }
+
+    sidecar_headers[static_cast<size_t>(kv_head_index) * static_cast<size_t>(rows_capacity) +
+                    static_cast<size_t>(dst_row)] = encoded_headers[linear_index];
+}
+
+bool openturbo_copy_row_indices_host(const ggml_tensor * tensor, std::vector<int64_t> & row_indices) {
+    row_indices.clear();
+    if (tensor == nullptr) {
+        return false;
+    }
+
+    const int64_t count = ggml_nelements(tensor);
+    if (count <= 0) {
+        return true;
+    }
+
+    row_indices.resize(static_cast<size_t>(count));
+    if (tensor->type == GGML_TYPE_I64) {
+        if (tensor->buffer != nullptr && ggml_backend_buffer_is_host(tensor->buffer)) {
+            std::memcpy(row_indices.data(), tensor->data, sizeof(int64_t) * row_indices.size());
+        } else {
+            ggml_backend_tensor_get(tensor, row_indices.data(), 0, sizeof(int64_t) * row_indices.size());
+        }
+        return true;
+    }
+
+    if (tensor->type == GGML_TYPE_I32) {
+        std::vector<int32_t> raw(static_cast<size_t>(count));
+        if (tensor->buffer != nullptr && ggml_backend_buffer_is_host(tensor->buffer)) {
+            std::memcpy(raw.data(), tensor->data, sizeof(int32_t) * raw.size());
+        } else {
+            ggml_backend_tensor_get(tensor, raw.data(), 0, sizeof(int32_t) * raw.size());
+        }
+
+        for (size_t i = 0; i < raw.size(); ++i) {
+            row_indices[i] = raw[i];
+        }
+        return true;
+    }
+
+    return false;
+}
+
+void openturbo_update_prefix_hint(ggml_cuda_openturbo_sidecar_entry & entry, const std::vector<int64_t> & row_indices) {
+    if (row_indices.empty()) {
+        return;
+    }
+
+    int64_t min_row = row_indices.front();
+    int64_t max_row = row_indices.front();
+    for (int64_t row : row_indices) {
+        min_row = std::min(min_row, row);
+        max_row = std::max(max_row, row);
+    }
+
+    if (min_row < 0 || max_row >= entry.rows_capacity) {
+        entry.contiguous_prefix = false;
+        return;
+    }
+
+    const int64_t next_prefix = max_row + 1;
+    if (!entry.contiguous_prefix) {
+        bool contiguous_from_zero = min_row == 0;
+        if (contiguous_from_zero) {
+            for (size_t i = 1; i < row_indices.size(); ++i) {
+                if (row_indices[i] != row_indices[i - 1] + 1) {
+                    contiguous_from_zero = false;
+                    break;
+                }
+            }
+        }
+
+        if (contiguous_from_zero) {
+            entry.contiguous_prefix = true;
+            entry.n_past_hint       = next_prefix;
+        }
+        return;
+    }
+
+    if (min_row <= entry.n_past_hint) {
+        entry.n_past_hint = std::max(entry.n_past_hint, next_prefix);
+    } else {
+        entry.contiguous_prefix = false;
+    }
+}
+}  // namespace
+
+bool ggml_cuda_openturbo_sidecar_update_from_set_rows(ggml_backend_cuda_context & ctx, ggml_tensor * set_rows) {
+    if (set_rows == nullptr || set_rows->op != GGML_OP_SET_ROWS) {
+        return false;
+    }
+
+    const ggml_tensor * src0         = set_rows->src[0];
+    const ggml_tensor * src1         = set_rows->src[1];
+    const ggml_tensor * cache_view   = set_rows->src[2];
+    const ggml_tensor * cache_tensor = openturbo_resolve_base_cache_tensor(cache_view);
+    if (src0 == nullptr || src1 == nullptr || !openturbo_is_named_k_cache(cache_tensor)) {
+        return false;
+    }
+
+    if (src0->type != GGML_TYPE_F32 && src0->type != GGML_TYPE_F16) {
+        return false;
+    }
+
+    if (cache_tensor->ne[0] <= 0 || (cache_tensor->ne[0] % OPENTURBO_TILE_DIMS) != 0) {
+        return false;
+    }
+
+    const int num_kv_heads = static_cast<int>(cache_tensor->ne[0] / OPENTURBO_TILE_DIMS);
+    if (num_kv_heads <= 0) {
+        return false;
+    }
+
+    const int64_t row_count = ggml_nelements(src1);
+    if (row_count <= 0 || src0->ne[0] != cache_tensor->ne[0]) {
+        return false;
+    }
+
+    const int64_t rows_capacity   = cache_tensor->ne[1] * cache_tensor->ne[2] * cache_tensor->ne[3];
+    const int64_t rows_per_stream = cache_tensor->ne[1];
+    const int64_t n_stream        = std::max<int64_t>(cache_tensor->ne[2], 1);
+    const size_t  encoded_count   = static_cast<size_t>(row_count) * static_cast<size_t>(num_kv_heads);
+
+    cudaStream_t                     stream          = ctx.stream();
+    openturbo_packed_tile_header_t * encoded_headers = nullptr;
+    int                              cuda_status     = cudaSuccess;
+    cuda_status = cudaMalloc(&encoded_headers, sizeof(openturbo_packed_tile_header_t) * encoded_count);
+    if (cuda_status != cudaSuccess) {
+        return false;
+    }
+
+    bool encode_ok = false;
+    if (src0->type == GGML_TYPE_F32) {
+        encode_ok = openturbo_encode_tile_fused_prerotated(static_cast<const float *>(src0->data), encoded_headers,
+                                                           static_cast<int>(encoded_count), stream,
+                                                           &cuda_status) == OPENTURBO_STATUS_SUCCESS;
+    } else {
+        encode_ok = openturbo_encode_tile_fused_prerotated_f16(static_cast<const uint16_t *>(src0->data),
+                                                               encoded_headers, static_cast<int>(encoded_count), stream,
+                                                               &cuda_status) == OPENTURBO_STATUS_SUCCESS;
+    }
+    if (!encode_ok) {
+        cudaFree(encoded_headers);
+        return false;
+    }
+
+    openturbo_packed_tile_header_t * sidecar_headers = nullptr;
+    {
+        std::lock_guard<std::mutex> lock(g_openturbo_sidecar_mutex);
+        auto &                      entry = g_openturbo_sidecars[cache_tensor];
+        if (entry.device_headers == nullptr || entry.rows_capacity != rows_capacity ||
+            entry.num_kv_heads != num_kv_heads) {
+            if (entry.device_headers != nullptr) {
+                cudaFree(entry.device_headers);
+            }
+            cuda_status = cudaMalloc(&entry.device_headers, sizeof(openturbo_packed_tile_header_t) *
+                                                                static_cast<size_t>(rows_capacity) *
+                                                                static_cast<size_t>(num_kv_heads));
