diff --git a/ggml/src/ggml-cuda/fattn.cu b/ggml/src/ggml-cuda/fattn.cu
index ea6607cd3..72e6f0db1 100644
--- a/ggml/src/ggml-cuda/fattn.cu
+++ b/ggml/src/ggml-cuda/fattn.cu
@@ -5,37 +5,345 @@
 #include "fattn-vec.cuh"
 #include "fattn-wmma-f16.cuh"
 #include "fattn.cuh"
+#include "openturbo-sidecar.cuh"
+
+#ifdef OPENTURBO_EXPERIMENTAL_PACKED_SCORE_PATH
+#    include "openturbo/c_api.h"
+
+namespace {
+constexpr int kOpenturboSoftmaxThreads = 256;
+constexpr int kOpenturboValueThreads   = 128;
+
+template <typename ValueType> static __device__ __forceinline__ float openturbo_load_scalar(const ValueType * ptr) {
+    return static_cast<float>(*ptr);
+}
+
+template <> __device__ __forceinline__ float openturbo_load_scalar<half>(const half * ptr) {
+    return __half2float(*ptr);
+}
+
+template <typename MaskType, bool HasMask>
+static __global__ void openturbo_scores_to_probs_kernel(float *          scores,
+                                                        const MaskType * mask,
+                                                        int              num_cache_tokens,
+                                                        float            scale) {
+    const int head_index  = blockIdx.x;
+    const int lane        = threadIdx.x;
+    float *   head_scores = scores + static_cast<size_t>(head_index) * static_cast<size_t>(num_cache_tokens);
+
+    __shared__ float reduction[kOpenturboSoftmaxThreads];
+
+    float local_max = -INFINITY;
+    for (int token_index = lane; token_index < num_cache_tokens; token_index += blockDim.x) {
+        float logit = head_scores[token_index] * scale;
+        if constexpr (HasMask) {
+            logit += openturbo_load_scalar(mask + token_index);
+        }
+        local_max = fmaxf(local_max, logit);
+    }
+
+    reduction[lane] = local_max;
+    __syncthreads();
+
+    for (int stride = blockDim.x / 2; stride > 0; stride >>= 1) {
+        if (lane < stride) {
+            reduction[lane] = fmaxf(reduction[lane], reduction[lane + stride]);
+        }
+        __syncthreads();
+    }
+
+    const float max_logit = reduction[0];
+
+    float local_sum = 0.0f;
+    for (int token_index = lane; token_index < num_cache_tokens; token_index += blockDim.x) {
+        float logit = head_scores[token_index] * scale;
+        if constexpr (HasMask) {
+            logit += openturbo_load_scalar(mask + token_index);
+        }
+
+        const float diff         = logit - max_logit;
+        const float prob         = diff >= SOFTMAX_FTZ_THRESHOLD ? expf(diff) : 0.0f;
+        head_scores[token_index] = prob;
+        local_sum += prob;
+    }
+
+    reduction[lane] = local_sum;
+    __syncthreads();
+
+    for (int stride = blockDim.x / 2; stride > 0; stride >>= 1) {
+        if (lane < stride) {
+            reduction[lane] += reduction[lane + stride];
+        }
+        __syncthreads();
+    }
+
+    const float inv_sum = reduction[0] > 0.0f ? 1.0f / reduction[0] : 0.0f;
+    for (int token_index = lane; token_index < num_cache_tokens; token_index += blockDim.x) {
+        head_scores[token_index] *= inv_sum;
+    }
+}
+
+template <typename ValueType>
+static __global__ void openturbo_weighted_value_sum_kernel(const float *     probs,
+                                                           const ValueType * values,
+                                                           float *           dst,
+                                                           int               dv,
+                                                           int               num_cache_tokens,
+                                                           int               num_query_heads,
+                                                           int               query_head_group,
+                                                           int64_t           value_nb0,
+                                                           int64_t           value_nb1,
+                                                           int64_t           value_nb2,
+                                                           int64_t           dst_nb0,
+                                                           int64_t           dst_nb1) {
+    const int     query_head_index = blockIdx.x;
+    const int     kv_head_index    = query_head_index / query_head_group;
+    const float * head_probs = probs + static_cast<size_t>(query_head_index) * static_cast<size_t>(num_cache_tokens);
+
+    GGML_UNUSED(num_query_heads);
+
+    for (int value_index = threadIdx.x; value_index < dv; value_index += blockDim.x) {
+        float total = 0.0f;
+        for (int token_index = 0; token_index < num_cache_tokens; ++token_index) {
+            const char * value_ptr =
+                reinterpret_cast<const char *>(values) + static_cast<int64_t>(value_index) * value_nb0 +
+                static_cast<int64_t>(token_index) * value_nb1 + static_cast<int64_t>(kv_head_index) * value_nb2;
+            total += head_probs[token_index] * openturbo_load_scalar(reinterpret_cast<const ValueType *>(value_ptr));
+        }
+
+        char * dst_ptr = reinterpret_cast<char *>(dst) + static_cast<int64_t>(value_index) * dst_nb0 +
+                         static_cast<int64_t>(query_head_index) * dst_nb1;
+        *reinterpret_cast<float *>(dst_ptr) = total;
+    }
+}
+
+static bool openturbo_is_decode_contract_supported(const ggml_tensor * dst) {
+    if (dst == nullptr || dst->op != GGML_OP_FLASH_ATTN_EXT || dst->type != GGML_TYPE_F32) {
+        return false;
+    }
+
+    const ggml_tensor * Q     = dst->src[0];
+    const ggml_tensor * K     = dst->src[1];
+    const ggml_tensor * V     = dst->src[2];
+    const ggml_tensor * mask  = dst->src[3];
+    const ggml_tensor * sinks = dst->src[4];
+    if (Q == nullptr || K == nullptr || V == nullptr || sinks != nullptr) {
+        return false;
+    }
+
+    float max_bias      = 0.0f;
+    float logit_softcap = 0.0f;
+    memcpy(&max_bias, (const float *) dst->op_params + 1, sizeof(float));
+    memcpy(&logit_softcap, (const float *) dst->op_params + 2, sizeof(float));
+    if (max_bias != 0.0f || logit_softcap != 0.0f) {
+        return false;
+    }
+
+    if (Q->ne[0] != OPENTURBO_TILE_DIMS || K->ne[0] != OPENTURBO_TILE_DIMS) {
+        return false;
+    }
+
+    if (Q->ne[1] != 1 || Q->ne[3] != 1 || K->ne[3] != 1 || V->ne[3] != 1) {
+        return false;
+    }
+
+    if (Q->ne[2] <= 0 || K->ne[1] <= 0 || K->ne[2] <= 0 || (Q->ne[2] % K->ne[2]) != 0) {
+        return false;
+    }
+
+    if ((Q->type != GGML_TYPE_F32 && Q->type != GGML_TYPE_F16) ||
+        (K->type != GGML_TYPE_F32 && K->type != GGML_TYPE_F16) ||
+        (V->type != GGML_TYPE_F32 && V->type != GGML_TYPE_F16)) {
+        return false;
+    }
+
+    const size_t q_type_size = ggml_type_size(Q->type);
+    const size_t k_type_size = ggml_type_size(K->type);
+    const size_t v_type_size = ggml_type_size(V->type);
+    if (Q->nb[0] != q_type_size || Q->nb[1] != static_cast<int64_t>(q_type_size * Q->ne[0]) ||
+        K->nb[0] != k_type_size || K->nb[1] != static_cast<int64_t>(k_type_size * K->ne[0]) ||
+        V->nb[0] != v_type_size || V->nb[1] != static_cast<int64_t>(v_type_size * V->ne[0])) {
+        return false;
+    }
+
+    if (mask != nullptr) {
+        if ((mask->type != GGML_TYPE_F16 && mask->type != GGML_TYPE_F32) || !ggml_is_contiguous(mask) ||
+            mask->ne[0] < K->ne[1] || mask->ne[3] != 1) {
+            return false;
+        }
+    }
+
+    return true;
+}
+
+static bool openturbo_encode_tensor_tiles(const ggml_tensor *              tensor,
+                                          openturbo_packed_tile_header_t * headers,
+                                          int                              num_tiles,
+                                          cudaStream_t                     stream,
+                                          int *                            cuda_status_out) {
+    if (tensor->type == GGML_TYPE_F32) {
+        return openturbo_encode_tile_fused_prerotated(static_cast<const float *>(tensor->data), headers, num_tiles,
+                                                      stream, cuda_status_out) == OPENTURBO_STATUS_SUCCESS;
+    }
+
+    if (tensor->type == GGML_TYPE_F16) {
+        return openturbo_encode_tile_fused_prerotated_f16(static_cast<const uint16_t *>(tensor->data), headers,
+                                                          num_tiles, stream,
+                                                          cuda_status_out) == OPENTURBO_STATUS_SUCCESS;
+    }
+
+    return false;
+}
+}  // namespace
+
+bool ggml_cuda_flash_attn_ext_openturbo_supported(const ggml_tensor * dst) {
+    return openturbo_is_decode_contract_supported(dst);
+}
+
+bool ggml_cuda_flash_attn_ext_openturbo(ggml_backend_cuda_context & ctx, ggml_tensor * dst) {
+    if (!openturbo_is_decode_contract_supported(dst)) {
+        return false;
+    }
+
+    const ggml_tensor * Q    = dst->src[0];
+    const ggml_tensor * K    = dst->src[1];
+    const ggml_tensor * V    = dst->src[2];
+    const ggml_tensor * mask = dst->src[3];
+
+    float scale = 1.0f;
+    memcpy(&scale, (const float *) dst->op_params + 0, sizeof(float));
+
+    ggml_cuda_openturbo_sidecar_view sidecar_view;
+    if (!ggml_cuda_openturbo_sidecar_lookup(K, &sidecar_view) || !sidecar_view.contiguous_prefix ||
+        sidecar_view.n_past <= 0) {
+        return false;
+    }
+
+    const int    num_query_heads    = static_cast<int>(Q->ne[2]);
+    const int    num_kv_heads       = static_cast<int>(K->ne[2]);
+    const int    query_head_group   = num_query_heads / num_kv_heads;
+    const int    num_cache_tokens   = static_cast<int>(std::min<int64_t>(sidecar_view.n_past, K->ne[1]));
+    const int    dv                 = static_cast<int>(V->ne[0]);
+    const int    query_header_count = num_query_heads;
+    const size_t score_count        = static_cast<size_t>(num_query_heads) * static_cast<size_t>(num_cache_tokens);
+    cudaStream_t stream             = ctx.stream();
+
+    openturbo_packed_tile_header_t * query_headers = nullptr;
+    float *                          scores        = nullptr;
+    int                              cuda_status   = cudaSuccess;
+
+    cuda_status =
+        cudaMalloc(&query_headers, sizeof(openturbo_packed_tile_header_t) * static_cast<size_t>(query_header_count));
+    if (cuda_status == cudaSuccess) {
+        cuda_status = cudaMalloc(&scores, sizeof(float) * score_count);
+    }
+    if (cuda_status != cudaSuccess) {
+        goto cleanup;
+    }
+
+    if (!openturbo_encode_tensor_tiles(Q, query_headers, query_header_count, stream, &cuda_status)) {
+        goto cleanup;
+    }
+
+    for (int query_head_index = 0; query_head_index < num_query_heads; ++query_head_index) {
+        const int                kv_head_index = query_head_index / query_head_group;
+        const openturbo_status_t scan_status   = openturbo_scan_query_many_cache_multi_tile(
+            query_headers + query_head_index,
+            sidecar_view.headers +
+                static_cast<size_t>(kv_head_index) * static_cast<size_t>(sidecar_view.rows_capacity) +
+                static_cast<size_t>(sidecar_view.row_offset),
+            scores + static_cast<size_t>(query_head_index) * static_cast<size_t>(num_cache_tokens), 1, num_cache_tokens,
+            stream, &cuda_status);
+        if (scan_status != OPENTURBO_STATUS_SUCCESS) {
+            goto cleanup;
+        }
+    }
+
+    if (mask == nullptr) {
+        openturbo_scores_to_probs_kernel<float, false>
+            <<<num_query_heads, kOpenturboSoftmaxThreads, 0, stream>>>(scores, nullptr, num_cache_tokens, scale);
+    } else if (mask->type == GGML_TYPE_F16) {
+        const half * mask_base =
+            reinterpret_cast<const half *>(static_cast<const char *>(mask->data) +
+                                           static_cast<size_t>(Q->ne[1] - 1) * static_cast<size_t>(mask->nb[1]));
+        openturbo_scores_to_probs_kernel<half, true>
+            <<<num_query_heads, kOpenturboSoftmaxThreads, 0, stream>>>(scores, mask_base, num_cache_tokens, scale);
+    } else {
+        const float * mask_base =
+            reinterpret_cast<const float *>(static_cast<const char *>(mask->data) +
+                                            static_cast<size_t>(Q->ne[1] - 1) * static_cast<size_t>(mask->nb[1]));
+        openturbo_scores_to_probs_kernel<float, true>
+            <<<num_query_heads, kOpenturboSoftmaxThreads, 0, stream>>>(scores, mask_base, num_cache_tokens, scale);
+    }
+    cuda_status = cudaGetLastError();
+    if (cuda_status != cudaSuccess) {
+        goto cleanup;
+    }
+
+    if (V->type == GGML_TYPE_F16) {
+        openturbo_weighted_value_sum_kernel<half><<<num_query_heads, kOpenturboValueThreads, 0, stream>>>(
+            scores, reinterpret_cast<const half *>(V->data), static_cast<float *>(dst->data), dv, num_cache_tokens,
+            num_query_heads, query_head_group, V->nb[0], V->nb[1], V->nb[2], dst->nb[0], dst->nb[1]);
+    } else {
+        openturbo_weighted_value_sum_kernel<float><<<num_query_heads, kOpenturboValueThreads, 0, stream>>>(
+            scores, static_cast<const float *>(V->data), static_cast<float *>(dst->data), dv, num_cache_tokens,
+            num_query_heads, query_head_group, V->nb[0], V->nb[1], V->nb[2], dst->nb[0], dst->nb[1]);
+    }
+    cuda_status = cudaGetLastError();
+    if (cuda_status != cudaSuccess) {
+        goto cleanup;
+    }
+
+    if (query_headers != nullptr) {
+        cudaFree(query_headers);
+    }
+    if (scores != nullptr) {
+        cudaFree(scores);
+    }
+    return true;
+
+cleanup:
+    if (query_headers != nullptr) {
+        cudaFree(query_headers);
+    }
+    if (scores != nullptr) {
+        cudaFree(scores);
+    }
+    return false;
+}
+#endif
 
