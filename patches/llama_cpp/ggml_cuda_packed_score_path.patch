+    auto                        it = g_openturbo_sidecars.find(cache_tensor);
+    if (it != g_openturbo_sidecars.end()) {
+        openturbo_update_prefix_hint(it->second, host_row_indices);
+    }
+
+    return true;
+}
+
+bool ggml_cuda_openturbo_sidecar_lookup(const ggml_tensor * cache_tensor, ggml_cuda_openturbo_sidecar_view * view_out) {
+    if (cache_tensor == nullptr || view_out == nullptr) {
+        return false;
+    }
+
+    const ggml_tensor * base_cache = openturbo_resolve_base_cache_tensor(cache_tensor);
+    if (!openturbo_is_named_k_cache(base_cache)) {
+        return false;
+    }
+
+    std::lock_guard<std::mutex> lock(g_openturbo_sidecar_mutex);
+    auto                        it = g_openturbo_sidecars.find(base_cache);
+    if (it == g_openturbo_sidecars.end() || it->second.device_headers == nullptr) {
+        return false;
+    }
+
+    const auto & entry      = it->second;
+    int64_t      row_offset = 0;
+    if (cache_tensor->view_src != nullptr && base_cache->nb[1] > 0) {
+        row_offset = static_cast<int64_t>(cache_tensor->view_offs / base_cache->nb[1]);
+    }
+
+    view_out->headers           = entry.device_headers;
+    view_out->rows_capacity     = entry.rows_capacity;
+    view_out->row_offset        = row_offset;
+    view_out->n_past            = entry.contiguous_prefix ? std::max<int64_t>(0, entry.n_past_hint - row_offset) : 0;
+    view_out->num_kv_heads      = entry.num_kv_heads;
+    view_out->contiguous_prefix = entry.contiguous_prefix;
+    return true;
+}
