+        ok = ggml_backend_cuda_openturbo_sidecar_copy(layer.k_stream[src_stream], layer.k_stream[dst_stream]) && ok;
+    }
+    return ok;
+#else
+    GGML_UNUSED(src_stream);
+    GGML_UNUSED(dst_stream);
